generator client {
  provider = "prisma-client-py"
  recursive_type_depth = -1
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  memberships     GroupMember[]
  posts           Post[]
  sentInvites     Invite[]      @relation("InviteSender")
  receivedInvites Invite[]   @relation("InviteReceiver")
  likes           PostLike[]
  ratings         PostRating[]
  comments        PostComment[]
  bids            Bid[]
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime @default(now())

  members  GroupMember[]
  posts    Post[]
  invites  Invite[]
}

model Invite {
  id        Int          @id @default(autoincrement())
  createdAt DateTime     @default(now())

  senderId   Int
  receiverId Int
  groupId    Int
  sender     User  @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User  @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  group      Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([receiverId, groupId]) // one pending invite per user per group
}

model GroupMember {
  id       Int              @id @default(autoincrement())
  role     GroupRole        @default(MEMBER)
  joinedAt DateTime         @default(now())

  userId  Int
  groupId Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId]) // a user can only join a group once
}

enum GroupRole {
  MEMBER
  OWNER
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model Post {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  visibility  Visibility @default(PRIVATE)

  authorId Int
  groupId  Int
  author   User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  images   PostImage[]
  likes    PostLike[]
  ratings  PostRating[]
  comments PostComment[]
  bids     Bid[]
}

model PostImage {
  id        Int      @id @default(autoincrement())
  url       String
  createdAt DateTime @default(now())

  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PostLike {
  createdAt DateTime @default(now())

  userId Int
  postId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostComment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  userId Int
  postId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model RatingCategory {
  id   Int    @id @default(autoincrement())
  name String @unique

  ratings PostRating[]
}

model PostRating {
  score Int  // 1-5

  userId     Int
  postId     Int
  categoryId Int
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   RatingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, categoryId])
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  PAID
}

model Bid {
  id        Int       @id @default(autoincrement())
  amount    Float
  status    BidStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  postId   Int
  bidderId Int
  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  bidder   User @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  payment Payment?
}

model Payment {
  id             Int      @id @default(autoincrement())
  amount         Float
  cardholderName String
  cardLast4      String
  createdAt      DateTime @default(now())

  bidId Int @unique
  bid   Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)
}
